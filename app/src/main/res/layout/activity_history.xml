<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="48dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp">

    <FrameLayout
        style="@style/WellnessHeaderBar">

        <ImageButton
            android:id="@+id/btnHistoryBack"
            style="@style/WellnessBackButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="start|center_vertical"
            app:tint="#111111" />

        <TextView
            style="@style/WellnessHeaderTitle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="All Wellness Data"
            android:textColor="#111111" />
    </FrameLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Date range"
        android:textColor="#111111"
        android:textSize="20sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etStartDate"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_filter_input"
            android:hint="Start"
            android:inputType="date"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:textColor="#111111"
            android:textColorHint="#9A9AA1"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/etEndDate"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_filter_input"
            android:hint="End"
            android:inputType="date"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:textColor="#111111"
            android:textColorHint="#9A9AA1"
            android:textSize="14sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnApplyFilter"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_primary_button"
        android:backgroundTint="@null"
        android:text="Apply Filter"
        android:textAllCaps="false"
        android:textColor="@color/function_button_text"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@null" />

    <ProgressBar
        android:id="@+id/progressHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="18dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvHistoryError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_delete_button"
        android:padding="12dp"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/tvHistoryEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:background="@drawable/bg_card"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="180dp"
            android:layout_height="150dp"
            android:contentDescription="Empty wellness history illustration"
            android:scaleType="centerCrop"
            android:src="@drawable/empty_state" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="No wellness records found."
            android:textColor="#6F7078"
            android:textSize="15sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerWellnessLogs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />
</LinearLayout>
