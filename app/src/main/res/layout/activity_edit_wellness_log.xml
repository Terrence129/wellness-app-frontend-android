<?xml version="1.0" encoding="utf-8"?>
<!-- Team5 -->
<!-- Author: Chen Chen -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="48dp"
        android:paddingEnd="22dp"
        android:paddingBottom="32dp">

        <FrameLayout
            style="@style/WellnessHeaderBar">

            <ImageButton
                android:id="@+id/btnBack"
                style="@style/WellnessBackButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="start|center_vertical"
                app:tint="#111111" />

            <TextView
                style="@style/WellnessHeaderTitle"
                android:text="Edit Wellness Log" />
        </FrameLayout>

        <TextView
            android:id="@+id/textError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:textColor="#FF3B30"
            android:textSize="14sp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:layout_marginTop="14dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textColor="#0A84FF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textLogDate"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/buttonPickDate"
                    android:layout_width="96dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_primary_button"
                    android:backgroundTint="@null"
                    android:text="Pick"
                    android:textAllCaps="false"
                    android:textColor="@color/function_button_text"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Health Summary"
                android:textColor="#0A84FF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Sleep Hours"
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputSleepHours"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:hint="Example: 8"
                android:inputType="numberDecimal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textColorHint="#8E8E93"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Mood Score"
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerMoodScore"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Water Cups"
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputWaterCups"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:hint="Example: 6"
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textColorHint="#8E8E93"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Activity"
                android:textColor="#0A84FF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Steps"
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputSteps"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:hint="Example: 8000"
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textColorHint="#8E8E93"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Exercise Minutes"
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputExerciseMinutes"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:hint="Example: 30"
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textColorHint="#8E8E93"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notes"
                android:textColor="#0A84FF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputNote"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:gravity="top"
                android:hint="Optional note"
                android:inputType="textMultiLine"
                android:padding="14dp"
                android:textColor="#111111"
                android:textColorHint="#8E8E93"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonUpdateLog"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="@drawable/bg_primary_button"
                android:backgroundTint="@null"
                android:text="Update"
                android:textAllCaps="false"
                android:textColor="@color/function_button_text"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/buttonDeleteLog"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_danger_outline_button"
                android:backgroundTint="@null"
                android:text="Delete"
                android:textAllCaps="false"
                android:textColor="#FF3B30"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
