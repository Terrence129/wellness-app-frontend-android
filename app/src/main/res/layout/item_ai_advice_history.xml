<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvAdviceHistoryDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/health_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvAdviceHistoryRange"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/health_text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvAdviceHistoryPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/health_text_primary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvAdviceHistoryModel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/health_text_secondary"
        android:textSize="12sp"
        android:visibility="gone" />
</LinearLayout>
