<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="48dp"
    android:paddingEnd="18dp"
    android:paddingBottom="16dp">

    <FrameLayout
        style="@style/WellnessHeaderBar">

        <ImageButton
            android:id="@+id/btnBack"
            style="@style/WellnessBackButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="start|center_vertical"
            app:tint="#111111" />

        <TextView
            style="@style/WellnessHeaderTitle"
            android:text="AI Coach" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_subtle"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="4dp">

        <Button
            android:id="@+id/btnModeAdvice"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_segment_selected"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:text="Advice"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnModeChat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_segment_unselected"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:text="Chat"
            android:textAllCaps="false"
            android:textColor="@color/health_text_secondary"
            android:textSize="14sp"
            app:backgroundTint="@null" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/advicePanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/tvRequestedRange"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Analysis period"
                    android:textColor="@color/health_text_secondary"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btnGenerateAdvice"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_primary_button"
                    android:text="Generate AI Advice"
                    android:textAllCaps="false"
                    android:textColor="@color/function_button_text"
                    app:backgroundTint="@null" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="24dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:textColor="@color/health_text_secondary"
                    android:textSize="15sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/adviceContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvAdviceDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/health_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAdviceRange"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/health_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvAdviceText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:textColor="@color/health_text_primary"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvModelName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/health_text_secondary"
                        android:textSize="13sp"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDisclaimer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:text="General wellness information only. This is not a medical diagnosis or treatment recommendation."
                    android:textColor="@color/health_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="italic" />
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/chatPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvChatMessages"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="10dp" />

            <TextView
                android:id="@+id/tvChatError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="6dp"
                android:textColor="@color/health_error"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvChatDisclaimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="General wellness information only. This chatbot does not provide medical diagnosis or treatment."
                android:textColor="@color/health_text_secondary"
                android:textSize="11sp"
                android:textStyle="italic" />

            <LinearLayout
                android:id="@+id/chatInputBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etChatMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:hint="Type a wellness question"
                    android:imeOptions="actionSend"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLength="2000"
                    android:maxLines="4"
                    android:minHeight="52dp"
                    android:padding="12dp"
                    android:textColor="@color/health_text_primary"
                    android:textColorHint="@color/health_text_secondary" />

                <Button
                    android:id="@+id/btnSendMessage"
                    android:layout_width="76dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:text="Send"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />

                <ProgressBar
                    android:id="@+id/chatProgressBar"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
