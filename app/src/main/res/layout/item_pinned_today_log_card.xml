<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/tvTodayStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/home_no_log_today"
        android:textColor="@color/health_orange"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSleepHours"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/sleep_hours_empty"
        android:textColor="@color/health_text_primary"
        android:textSize="28sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvMoodScore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_card_subtle"
            android:padding="12dp"
            android:text="@string/mood_score_empty"
            android:textColor="#34343A"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvWaterCups"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card_subtle"
            android:padding="12dp"
            android:text="@string/water_cups_empty"
            android:textColor="#34343A"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvSteps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_card_subtle"
            android:padding="12dp"
            android:text="@string/steps_empty"
            android:textColor="#34343A"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvExerciseMinutes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card_subtle"
            android:padding="12dp"
            android:text="@string/exercise_minutes_empty"
            android:textColor="#34343A"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/home_no_note"
        android:textColor="@color/health_text_secondary"
        android:textSize="14sp" />
</LinearLayout>
