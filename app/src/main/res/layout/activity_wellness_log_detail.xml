     Author: 罗钰翔 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/member_f_screen_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="34dp"
        android:paddingEnd="18dp"
        android:paddingBottom="28dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="52dp">

            <Button
                android:id="@+id/btnDetailBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="start|center_vertical"
                android:background="@drawable/member_f_circle_button"
                android:text="‹"
                android:textAllCaps="false"
                android:textColor="#111111"
                android:textSize="30sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Wellness Detail"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <ProgressBar
            android:id="@+id/progressDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvDetailError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/member_f_danger_button"
            android:padding="12dp"
            android:textColor="#B42318"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvDetailDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="2026-06-24"
            android:textColor="#6F7078"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/member_f_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tvDetailExercise"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Exercise: -- min"
                android:textColor="#FF5A1F"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailSteps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Steps: --"
                android:textColor="#111111"
                android:textSize="32sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivDetailChart"
                android:layout_width="match_parent"
                android:layout_height="230dp"
                android:layout_marginTop="12dp"
                android:adjustViewBounds="true"
                android:contentDescription="Wellness metric bar chart"
                android:scaleType="centerCrop"
                android:src="@drawable/member_f_detail_chart" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Details"
            android:textColor="#111111"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/member_f_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tvDetailSleep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sleep: -- h"
                android:textColor="#111111"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvDetailMood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Mood: -- / 5"
                android:textColor="#111111"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvDetailWater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Water: -- cups"
                android:textColor="#111111"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvDetailNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="No notes yet."
                android:textColor="#6F7078"
                android:textSize="15sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnEditLog"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/member_f_primary_button"
            android:text="Edit"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnDeleteLog"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/member_f_danger_button"
            android:text="Delete"
            android:textAllCaps="false"
            android:textColor="#D64E25"
            android:textSize="15sp" />
    </LinearLayout>
</ScrollView>
