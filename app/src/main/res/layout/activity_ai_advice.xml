<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="48dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <FrameLayout
            style="@style/WellnessHeaderBar">

            <ImageButton
                android:id="@+id/btnBack"
                style="@style/WellnessBackButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="start|center_vertical"
                app:tint="#111111" />

            <TextView
                style="@style/WellnessHeaderTitle"
                android:text="AI Wellness Advice" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvRequestedRange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Analysis period"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnGenerateAdvice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_primary_button"
            android:backgroundTint="@null"
            android:textColor="@color/function_button_text"
            android:text="Generate AI Advice"
            app:backgroundTint="@null" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:textSize="16sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/adviceContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvAdviceDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAdviceRange"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvAdviceText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:padding="16dp"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tvModelName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Advice History"
            android:textColor="@color/health_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etAdviceHistoryStartDate"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_filter_input"
                android:focusable="false"
                android:hint="Start"
                android:inputType="date"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:textColor="@color/health_text_primary"
                android:textColorHint="@color/health_text_secondary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etAdviceHistoryEndDate"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_filter_input"
                android:focusable="false"
                android:hint="End"
                android:inputType="date"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:textColor="@color/health_text_primary"
                android:textColorHint="@color/health_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnApplyAdviceHistoryFilter"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_primary_button"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:text="Apply"
                android:textAllCaps="false"
                android:textColor="@color/function_button_text"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnClearAdviceHistoryFilter"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_outline_button"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:text="Clear"
                android:textAllCaps="false"
                android:textColor="@color/function_button_background"
                app:backgroundTint="@null" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressAdviceHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="14dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvAdviceHistoryStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textColor="@color/health_text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAdviceHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false" />

        <Button
            android:id="@+id/btnLoadMoreAdviceHistory"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_outline_button"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:text="Load More"
            android:textAllCaps="false"
            android:textColor="@color/function_button_background"
            android:visibility="gone"
            app:backgroundTint="@null" />

        <TextView
            android:id="@+id/tvDisclaimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:text="This advice is for general wellness purposes only and is not a medical diagnosis or treatment recommendation."
            android:textSize="13sp"
            android:textStyle="italic" />

    </LinearLayout>

</ScrollView>
