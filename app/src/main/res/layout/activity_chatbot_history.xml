<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="48dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp">

    <FrameLayout style="@style/WellnessHeaderBar">

        <ImageButton
            android:id="@+id/btnBack"
            style="@style/WellnessBackButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="start|center_vertical"
            app:tint="#111111" />

        <TextView
            style="@style/WellnessHeaderTitle"
            android:text="Chat History" />
    </FrameLayout>

    <ProgressBar
        android:id="@+id/progressChatHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvChatHistoryStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textColor="@color/health_text_secondary"
        android:textSize="14sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatConversations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false" />

    <Button
        android:id="@+id/btnLoadMoreChatHistory"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_outline_button"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:text="Load More"
        android:textAllCaps="false"
        android:textColor="@color/function_button_background"
        android:visibility="gone"
        app:backgroundTint="@null" />

    <TextView
        android:id="@+id/tvSelectedConversationTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Conversation"
        android:textColor="@color/health_text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:visibility="gone" />
</LinearLayout>
